import cv2
import numpy as np
import matplotlib.pyplot as plt

# ==========================================
# 1. Fonctions de Génération des Noyaux (PSF)
# ==========================================

def create_motion_blur_kernel(size, angle):
    """Crée un noyau de flou de mouvement (PSF linéaire)."""
    kernel = np.zeros((size, size), dtype=np.float32)
    center = size // 2
    
    angle_rad = np.deg2rad(angle)
    x = int(np.cos(angle_rad) * center)
    y = int(np.sin(angle_rad) * center)
    
    cv2.line(kernel, (center - x, center - y), (center + x, center + y), 1, thickness=1)
    kernel /= np.sum(kernel)
    return kernel

def create_defocus_kernel(radius):
    """Crée un noyau de flou de mise au point (PSF circulaire)."""
    if radius == 0:
        return np.ones((1, 1), dtype=np.float32)
    size = 2 * radius + 1
    kernel = np.zeros((size, size), dtype=np.float32)
    center = radius
    
    cv2.circle(kernel, (center, center), radius, 1, thickness=-1)
    kernel /= np.sum(kernel)
    return kernel

# ==========================================
# 2. Fonctions de Dégradation & Restauration
# ==========================================

def apply_blur_and_noise(image, kernel, noise_var):
    """Applique le PSF à l'image et ajoute du bruit gaussien."""
    blurred = cv2.filter2D(image, -1, kernel)
    
    row, col = image.shape
    mean = 0
    sigma = noise_var ** 0.5
    gauss = np.random.normal(mean, sigma, (row, col))
    
    noisy_blurred = blurred + gauss
    return np.clip(noisy_blurred, 0, 255).astype(np.uint8)

def wiener_deconvolution(blurred_img, kernel, nsr_lambda):
    """Applique la déconvolution de Wiener dans le domaine fréquentiel."""
    h_img, w_img = blurred_img.shape
    h_ker, w_ker = kernel.shape
    
    pad_h = h_img - h_ker
    pad_w = w_img - w_ker
    padded_kernel = np.pad(kernel, ((0, pad_h), (0, pad_w)), 'constant')
    
    G = np.fft.fft2(blurred_img)
    H = np.fft.fft2(padded_kernel)
    
    H_conj = np.conj(H)
    H_squared_mag = np.abs(H) ** 2
    
    W = H_conj / (H_squared_mag + nsr_lambda)
    F_prime = G * W
    
    f_prime_spatial = np.abs(np.fft.ifft2(F_prime))
    
    # Correction du décalage pour recentrer l'image
    shift_y, shift_x = h_ker // 2, w_ker // 2
    f_prime_spatial = np.roll(f_prime_spatial, shift_y, axis=0)
    f_prime_spatial = np.roll(f_prime_spatial, shift_x, axis=1)
    
    return np.clip(f_prime_spatial, 0, 255).astype(np.uint8)

def calculate_psnr(img1, img2):
    """Calcule le Peak Signal-to-Noise Ratio (PSNR)."""
    mse = np.mean((img1.astype(np.float64) - img2.astype(np.float64)) ** 2)
    if mse == 0:
        return float('inf')
    max_pixel = 255.0
    psnr = 20 * np.log10(max_pixel / np.sqrt(mse))
    return psnr

# ==========================================
# Exécution Principale
# ==========================================
if __name__ == "__main__":
    
    # ==========================================
    # PIPELINE 1: SIMULATION (Test des mathématiques)
    # ==========================================
    print("--- Lancement du Pipeline de Simulation ---")
    
    # Chemin vers l'image nette dans votre dossier data
    sim_path = "../data/morocco.jpg" 
    sim_image = cv2.imread(sim_path, cv2.IMREAD_GRAYSCALE)
    
    if sim_image is not None:
        sim_blur_size = 129
        sim_blur_angle = 30
        sim_noise_variance = 5.0
        sim_nsr_lambda = 0.005
        
        sim_psf = create_motion_blur_kernel(sim_blur_size, sim_blur_angle)
        sim_degraded = apply_blur_and_noise(sim_image, sim_psf, sim_noise_variance)
        sim_restored = wiener_deconvolution(sim_degraded, sim_psf, sim_nsr_lambda)
        
        plt.figure(figsize=(15, 4))
        plt.suptitle("PIPELINE 1: Simulation (Faux Flou de Mouvement + Bruit)", fontsize=14, fontweight='bold')
        
        plt.subplot(1, 3, 1)
        plt.title("Image Nette (Local)")
        plt.imshow(sim_image, cmap='gray')
        plt.axis('off')
        
        plt.subplot(1, 3, 2)
        plt.title(f"Dégradée (Taille: {sim_blur_size})")
        plt.imshow(sim_degraded, cmap='gray')
        plt.axis('off')
        
        plt.subplot(1, 3, 3)
        plt.title(f"Restaurée (NSR={sim_nsr_lambda})")
        plt.imshow(sim_restored, cmap='gray')
        plt.axis('off')
        
        plt.tight_layout()
        plt.show() # J'ai rajouté ce plt.show() pour afficher la simulation indépendamment
    else:
        print(f"Erreur : Impossible de charger l'image depuis {sim_path}")

    # ==========================================
    # PIPELINE 2: CAS RÉEL (Fichier local)
    # ==========================================
    print("\n--- Lancement du Pipeline Réel ---")
    
    # Chemin vers l'image floue (voiture verte) dans votre dossier data
    real_path = "../data/green_car.jpg" 
    real_image_full = cv2.imread(real_path, cv2.IMREAD_GRAYSCALE)
    
    if real_image_full is not None:
        # 1. ROGNAGE (Crop) avec vos paramètres originaux
        h, w = real_image_full.shape
        cropped_plate = real_image_full[int(h*0.43):int(h*0.64), int(w*0.39):int(w*0.73)]
        
        # 2. Paramètres pour une vraie photo
        real_guessed_radius = 12  
        real_psf = create_defocus_kernel(real_guessed_radius)
        real_nsr_lambda = 0.009   
        
        # 3. Déconvolution Directe
        real_restored = wiener_deconvolution(cropped_plate, real_psf, real_nsr_lambda)
        
        # 4. Affichage
        plt.figure(figsize=(12, 5))
        plt.suptitle("PIPELINE 2: Restauration Réelle (Ciblée sur la plaque)", fontsize=14, fontweight='bold')
        
        plt.subplot(1, 2, 1)
        plt.title("Image Originale (Rognée)")
        plt.imshow(cropped_plate, cmap='gray')
        plt.axis('off')
        
        plt.subplot(1, 2, 2)
        plt.title(f"Restaurée (Rayon Deviné: {real_guessed_radius}, NSR: {real_nsr_lambda})")
        plt.imshow(real_restored, cmap='gray')
        plt.axis('off')
        
        plt.tight_layout()
        plt.show() 
        
    else:
        print(f"Erreur : Impossible de charger l'image depuis {real_path}")
